{
  "id": "paternity-leave-request-by-pritesh-chavan",
  "title": "Paternity Leave Request",
  "createdBy": "Pritesh Chavan",
  "workspaceName": "Acme Inc",
  "personas": [
    {
      "id": "alex",
      "name": "Alex Kim",
      "designation": "Employee",
      "role": "Replies in #team-leave, applies for paternity leave in Slackbot, receives approval confirmation",
      "type": "user"
    },
    {
      "id": "sarah",
      "name": "Sarah Chen",
      "designation": "Manager",
      "role": "Asks about team leave in-channel; approves Alex's request in Slackbot",
      "type": "user"
    },
    {
      "id": "slackbot",
      "name": "Slackbot",
      "designation": "App",
      "role": "Explains policy, collects dates, routes approval to Sarah, confirms outcomes",
      "type": "app"
    }
  ],
  "steps": [
    {
      "id": "step-1",
      "type": "surface",
      "context": {
        "surface": "channel",
        "channel": "#team-leave"
      }
    },
    {
      "id": "step-2",
      "type": "thread_reply",
      "content": {
        "actor": "user",
        "personaId": "sarah",
        "text": "Who's taking leave this month?"
      }
    },
    {
      "id": "step-3",
      "type": "thread_reply",
      "content": {
        "actor": "user",
        "personaId": "alex",
        "text": "I'd like to take leave."
      }
    },
    {
      "id": "step-4",
      "type": "surface",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "context": {
        "surface": "dm",
        "with": "Slackbot"
      }
    },
    {
      "id": "step-5",
      "type": "user_message",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "text": "I want to apply for paternity leave.",
        "personaId": "alex"
      }
    },
    {
      "id": "step-6",
      "type": "bot_typing",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "duration": 1,
        "statusText": "Pulling your leave policy and routing rules…"
      }
    },
    {
      "id": "step-7",
      "type": "app_message",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "personaId": "slackbot",
        "templateId": "text_with_buttons",
        "text": "I've noticed you're planning a life event—congrats, Alex.\n\n*Paternity leave in your workspace*\n\u2022 Up to 2 weeks paid once approved\n\u2022 Your manager (Sarah Chen) approves in Slack\n\u2022 I'll sync dates with HR systems after approval\n\nWhen you're ready, lock in your dates and I'll route the request.\n\nChoose an action below to continue.",
        "choices": ["Choose dates"]
      }
    },
    {
      "id": "step-8",
      "type": "user_action",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "action": "open_leave_dates",
        "trigger": "button",
        "personaId": "alex",
        "choices": ["Choose dates"]
      }
    },
    {
      "id": "step-9",
      "type": "modal_open",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "view": "date-picker"
      }
    },
    {
      "id": "step-10",
      "type": "modal_submit",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "values": {
          "start": "2026-03-15",
          "end": "2026-03-22"
        }
      }
    },
    {
      "id": "step-10a",
      "type": "bot_typing",
      "viewport": {
        "mode": "dual",
        "left": "channel",
        "right": "slackbot"
      },
      "content": {
        "duration": 1,
        "statusText": "Routing the request to Sarah…"
      }
    },
    {
      "id": "step-11",
      "type": "surface",
      "viewport": {
        "mode": "single",
        "view": "slackbot"
      },
      "context": {
        "surface": "dm",
        "with": "Slackbot",
        "resetConversation": true
      }
    },
    {
      "id": "step-12",
      "type": "app_message",
      "content": {
        "personaId": "slackbot",
        "templateId": "text_with_buttons",
        "text": "Hi Sarah—Alex Kim has requested *paternity leave*.\n\n*Request summary*\n\u2022 Dates: March 15\u201322, 2026\n\u2022 Type: Paternity\n\u2022 Routed from your team's #team-leave context\n\nYou can approve or reject here; I'll close the loop with Alex automatically.\n\nChoose an action below to continue.",
        "choices": ["Approve", "Reject"]
      }
    },
    {
      "id": "step-13",
      "type": "user_action",
      "content": {
        "action": "approve_paternity_leave",
        "trigger": "button",
        "personaId": "sarah",
        "choices": ["Approve"]
      }
    },
    {
      "id": "step-14",
      "type": "app_message",
      "content": {
        "personaId": "slackbot",
        "templateId": "plain_text",
        "text": "I've handled the notification—Alex knows you've approved.\n\n*What I've done in your workspace*\n\u2022 Recorded your approval on the leave case\n\u2022 Messaged Alex with the confirmed dates\n\u2022 Queued HR calendar updates for March 15\u201322\n\nThanks for the quick turnaround."
      }
    },
    {
      "id": "step-15",
      "type": "surface",
      "context": {
        "surface": "dm",
        "with": "Slackbot",
        "personaId": "alex",
        "resetConversation": true
      }
    },
    {
      "id": "step-16",
      "type": "app_message",
      "content": {
        "personaId": "slackbot",
        "templateId": "plain_text",
        "text": "Great news, Alex!\n\n*Your leave is approved*\n\u2022 Dates: March 15\u201322, 2026\n\u2022 Sarah Chen signed off—I've updated your case\n\nYou're all set. If anything shifts, just ping me here and I'll re-orchestrate with HR."
      }
    }
  ]
}
